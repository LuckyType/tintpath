{
  "name": "tintpath",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Create paint-by-numbers templates from images — 100% in the browser",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "knip": "knip --no-progress"
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "svelte-i18n": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@testing-library/svelte": "^5.2.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "knip": "^5.41.0",
    "postcss": "^8.4.49",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
